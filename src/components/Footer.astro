---
const year = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">

      <!-- Columna 1: Empresa -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4">ClimaEco Aerotermia</h3>
        <p class="text-white/80 text-sm leading-relaxed">
          Especialistas en instalación y mantenimiento de sistemas de aerotermia en Madrid. Climatización eficiente para hogares y empresas.
        </p>
      </div>

      <!-- Columna 2: Servicios -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4">Servicios</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/instalacion-aerotermia/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Instalación de Aerotermia</a></li>
          <li><a href="/aerotermia-suelo-radiante/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Aerotermia con Suelo Radiante</a></li>
          <li><a href="/mantenimiento-aerotermia/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Mantenimiento de Aerotermia</a></li>
        </ul>
      </div>

      <!-- Columna 3: Zonas y Guías -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4">Zonas</h3>
        <ul class="flex flex-col gap-2 mb-6">
          <li><a href="/madrid/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Aerotermia en Madrid</a></li>
          <li><a href="/instalacion-aerotermia/madrid/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Instalación en Madrid</a></li>
          <li><a href="/aerotermia-suelo-radiante/madrid/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Suelo Radiante en Madrid</a></li>
          <li><a href="/mantenimiento-aerotermia/madrid/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Mantenimiento en Madrid</a></li>
        </ul>
        <h3 class="text-white text-base font-semibold mb-3">Guías</h3>
        <ul class="flex flex-col gap-2">
          <li><a href="/madrid/cuanto-cuesta-instalar-aerotermia/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">¿Cuánto cuesta instalar aerotermia?</a></li>
          <li><a href="/madrid/aerotermia-vs-caldera-gas/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Aerotermia vs Caldera de Gas</a></li>
          <li><a href="/madrid/precio-aerotermia-suelo-radiante/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">Precio aerotermia suelo radiante</a></li>
          <li><a href="/madrid/cada-cuanto-mantenimiento-aerotermia/" class="text-white/80 text-sm hover:text-accent transition-colors no-underline">¿Cada cuánto mantenimiento?</a></li>
        </ul>
      </div>

      <!-- Columna 4: Contacto (Output 1.1) -->
      <div>
        <h3 class="text-white text-lg font-semibold mb-4">Contacto</h3>
        <ul class="flex flex-col gap-3">
          <li class="flex items-start gap-2 text-white/80 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
