          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@climaecoaerotermia.es" class="text-white/80 text-sm no-underline hover:text-accent transition-colors">info@climaecoaerotermia.es</a>
          </li>
        </ul>
        <div class="mt-6">
          <a href="/contacto/" class="btn-primary text-sm">Pedir presupuesto</a>
        </div>
      </div>

    </div>
  </div>

  <!-- Barra inferior -->
  <div class="border-t border-white/20">
    <div class="container py-4 flex flex-col md:flex-row items-center justify-between gap-2">
      <p class="text-white/60 text-xs m-0">
        &copy; {year} ClimaEco Aerotermia Madrid. Todos los derechos reservados.
      </p>
      <div class="flex gap-4">
        <a href="/aviso-legal/" class="text-white/60 text-xs hover:text-white transition-colors no-underline">Aviso legal</a>
        <a href="/politica-privacidad/" class="text-white/60 text-xs hover:text-white transition-colors no-underline">Privacidad</a>
      </div>
    </div>
  </div>
</footer>
