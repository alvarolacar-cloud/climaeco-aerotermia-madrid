---
const nav = [
  {
    label: 'Servicios',
    href: null,
    children: [
      { label: 'Instalación de Aerotermia', href: '/instalacion-aerotermia/' },
      { label: 'Aerotermia y Suelo Radiante', href: '/aerotermia-suelo-radiante/' },
      { label: 'Mantenimiento', href: '/mantenimiento-aerotermia/' },
    ],
  },
  {
    label: 'Zonas',
    href: null,
    children: [
      { label: 'Madrid', href: '/madrid/' },
    ],
  },
  {
    label: 'Guías',
    href: null,
    children: [
      { label: 'Cuánto cuesta instalar aerotermia', href: '/madrid/cuanto-cuesta-instalar-aerotermia/' },
      { label: 'Aerotermia vs Caldera de Gas', href: '/madrid/aerotermia-vs-caldera-gas/' },
      { label: 'Precio aerotermia con suelo radiante', href: '/madrid/precio-aerotermia-suelo-radiante/' },
      { label: 'Cada cuánto mantenimiento aerotermia', href: '/madrid/cada-cuanto-mantenimiento-aerotermia/' },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-primary text-white sticky top-0 z-50 shadow-md">
  <div class="container flex items-center justify-between py-4">
    <!-- Logo / Nombre empresa -->
    <a href="/" class="text-white font-bold text-xl no-underline hover:no-underline hover:text-accent transition-colors">
      ClimaEco Aerotermia
    </a>

    <!-- Teléfono visible (Output 1.1) -->
    <a href="tel:+34910555123" class="hidden md:flex items-center gap-2 text-accent font-semibold text-sm no-underline hover:no-underline hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      +34 910 555 123
    </a>

    <!-- Navegación escritorio -->
    <nav class="hidden md:flex items-center gap-6">
      <a href="/" class={`text-sm font-medium transition-colors hover:text-accent ${currentPath === '/' ? 'text-accent' : 'text-white'}`}>
        Inicio
      </a>

      {nav.map((item) => (
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm font-medium text-white hover:text-accent transition-colors cursor-pointer bg-transparent border-none">
            {item.label}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-64 bg-white text-text shadow-lg rounded-base opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {item.children?.map((child) => (
              <a
                href={child.href}
                class={`block px-4 py-3 text-sm hover:bg-gray-50 hover:text-primary transition-colors no-underline border-b border-gray-100 last:border-0 ${currentPath === child.href ? 'text-primary font-semibold' : 'text-text'}`}
              >
                {child.label}
              </a>
            ))}
          </div>
        </div>
      ))}

      <a href="/contacto/" class="btn-primary text-sm py-2 px-5">
        Contacto
      </a>
    </nav>

    <!-- Botón menú móvil -->
    <button id="menu-toggle" class="md:hidden text-white" aria-label="Abrir menú">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="hidden md:hidden bg-primary border-t border-white/20">
    <div class="container py-4 flex flex-col gap-2">
      <a href="/" class="text-white text-sm font-medium py-2 border-b border-white/10">Inicio</a>
      {nav.map((item) => (
        <>
          <span class="text-accent text-xs font-semibold uppercase tracking-wider pt-3">{item.label}</span>
          {item.children?.map((child) => (
            <a href={child.href} class="text-white/90 text-sm py-1.5 pl-3 hover:text-accent transition-colors no-underline">
              {child.label}
            </a>
          ))}
        </>
      ))}
      <a href="/contacto/" class="btn-primary text-center mt-3">Contacto</a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
