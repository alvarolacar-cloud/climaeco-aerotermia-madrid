---
export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Solicita tu presupuesto gratuito',
  subtitle = 'Te respondemos en menos de 24 horas.',
} = Astro.props;
---

<section class="bg-gray-50 py-16">
  <div class="container max-w-2xl">
    <h2 class="text-primary text-center mb-2">{title}</h2>
    {subtitle && <p class="text-center text-text mb-8">{subtitle}</p>}

    <form
      name="contacto"
      method="POST"
      action="/gracias/"
      class="flex flex-col gap-5 bg-white p-8 rounded-base shadow-sm border border-gray-100"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="flex flex-col gap-1">
          <label for="nombre" class="text-sm font-semibold text-primary">Nombre *</label>
          <input
            type="text"
            id="nombre"
            name="nombre"
            required
            placeholder="Tu nombre"
            class="border border-gray-300 rounded-base px-4 py-3 text-base focus:outline-none focus:border-secondary transition-colors"
          />
        </div>
        <div class="flex flex-col gap-1">
          <label for="telefono" class="text-sm font-semibold text-primary">Teléfono *</label>
          <input
            type="tel"
            id="telefono"
            name="telefono"
            required
            placeholder="Tu teléfono"
            class="border border-gray-300 rounded-base px-4 py-3 text-base focus:outline-none focus:border-secondary transition-colors"
          />
        </div>
      </div>

      <div class="flex flex-col gap-1">
        <label for="email" class="text-sm font-semibold text-primary">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="tu@email.com"
          class="border border-gray-300 rounded-base px-4 py-3 text-base focus:outline-none focus:border-secondary transition-colors"
        />
      </div>

      <div class="flex flex-col gap-1">
        <label for="servicio" class="text-sm font-semibold text-primary">Servicio de interés</label>
        <select
          id="servicio"
          name="servicio"
          class="border border-gray-300 rounded-base px-4 py-3 text-base focus:outline-none focus:border-secondary transition-colors bg-white"
        >
          <option value="">Selecciona un servicio</option>
          <option value="instalacion">Instalación de Aerotermia</option>
          <option value="suelo-radiante">Aerotermia con Suelo Radiante</option>
          <option value="mantenimiento">Mantenimiento de Aerotermia</option>
        </select>
      </div>

      <div class="flex flex-col gap-1">
        <label for="mensaje" class="text-sm font-semibold text-primary">Mensaje</label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          placeholder="Cuéntanos sobre tu vivienda o proyecto..."
          class="border border-gray-300 rounded-base px-4 py-3 text-base focus:outline-none focus:border-secondary transition-colors resize-none"
        ></textarea>
      </div>

      <button type="submit" class="btn-primary text-center text-base w-full">
        Enviar solicitud
      </button>

      <p class="text-xs text-gray-400 text-center m-0">
        Al enviar este formulario aceptas nuestra <a href="/politica-privacidad/" class="underline">política de privacidad</a>.
      </p>
    </form>
  </div>
</section>
