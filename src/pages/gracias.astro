---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="¡Gracias por tu mensaje! | ClimaEco Aerotermia Madrid"
  description="Hemos recibido tu solicitud. Te contactaremos en menos de 24 horas."
  canonical="/gracias/"
>
  <section class="bg-primary text-white py-24">
    <div class="container max-w-2xl text-center">
      <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-white text-4xl font-normal mb-4">¡Gracias por tu mensaje!</h1>
      <p class="text-white/85 text-xl mb-8">
        Hemos recibido tu solicitud. Te contactaremos en menos de <strong>24 horas</strong> con un presupuesto detallado.
      </p>
      <a href="/" class="btn-primary text-base">Volver al inicio</a>
    </div>
  </section>
</Layout>
