---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "ClimaEco Aerotermia Madrid",
  "url": "https://climaecoaerotermia.es/contacto/",
  "telephone": "+34910555123",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Calle de Rafael Calvo 40",
    "addressLocality": "Madrid",
    "postalCode": "28010",
    "addressCountry": "ES"
  }
};
---

<Layout
  title="Contacto | ClimaEco Aerotermia Madrid — Presupuesto gratuito"
  description="Contacta con ClimaEco Aerotermia Madrid. Solicita tu presupuesto gratuito de instalación o mantenimiento de aerotermia. Respondemos en menos de 24 horas."
  canonical="/contacto/"
  schema={schemaLocalBusiness}
>
  <!-- Hero Contacto -->
  <section class="bg-primary text-white py-16">
    <div class="container max-w-3xl text-center">
      <h1 class="text-white text-4xl font-normal mb-4">Contacta con nosotros</h1>
      <p class="text-white/85 text-xl">
        Solicita tu presupuesto gratuito. Respondemos en menos de 24 horas.
      </p>
    </div>
  </section>

  <!-- Datos de contacto + Formulario -->
  <section class="bg-gray-50 py-16">
    <div class="container">
      <div class="flex flex-col md:flex-row gap-12 max-w-5xl mx-auto">

        <!-- Datos de contacto -->
        <div class="md:w-1/3">
          <h2 class="text-primary mb-6">Información de contacto</h2>
          <ul class="flex flex-col gap-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <p class="font-semibold text-primary text-sm mb-1">Teléfono</p>
                <a href="tel:+34910555123" class="text-accent font-bold text-lg no-underline hover:text-primary transition-colors">+34 910 555 123</a>
                <p class="text-text text-xs mt-1 m-0">Lunes a viernes, 9h — 18h</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-semibold text-primary text-sm mb-1">Email</p>
                <a href="mailto:info@climaecoaerotermia.es" class="text-secondary text-sm no-underline hover:text-primary transition-colors">info@climaecoaerotermia.es</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="font-semibold text-primary text-sm mb-1">Dirección</p>
                <p class="text-text text-sm m-0">Calle de Rafael Calvo 40<br/>28010 Madrid</p>
              </div>
            </li>
          </ul>

          <div class="mt-8 bg-primary/5 border border-primary/20 rounded-base p-5">
            <p class="text-primary font-semibold text-sm mb-2">¿Urgente?</p>
            <p class="text-text text-sm leading-relaxed m-0">
              Para averías urgentes, llámanos directamente. Disponemos de servicio de reparación con respuesta en menos de 24 horas en Madrid.
            </p>
          </div>
        </div>

        <!-- Formulario -->
        <div class="md:w-2/3">
          <ContactForm
            title="Solicita tu presupuesto gratuito"
            subtitle="Rellena el formulario y te respondemos en menos de 24 horas."
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
